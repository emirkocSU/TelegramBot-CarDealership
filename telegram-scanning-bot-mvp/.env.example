# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# Database Configuration
DATABASE_URL=sqlite:///./car_alert_bot.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=bot.log

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# Car Scanner Configuration
SCAN_INTERVAL=300  # seconds (5 minutes)
BASE_LISTING_URL=https://www.sahibinden.com/otomobil
MAX_LISTINGS_PER_SCAN=50
REQUEST_DELAY=1.0  # seconds between requests

# YOLOv8 Configuration (for future real implementation)
YOLO_WEIGHTS_PATH=models/car_damage_yolo.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_MAX_IMAGES=5

# Webhook Configuration (optional)
WEBHOOK_URL=
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook

# Development/Testing
DEBUG=False
TESTING=False

# Mobile App Integration
MOBILE_APP_SECRET=your_mobile_app_secret_key
DEEP_LINK_BASE_URL=https://your-app.com/link

# External Services
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36