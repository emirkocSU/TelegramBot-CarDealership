    "@react-navigation/stack": "^6.3.16",
    "expo": "~49.0.15",
    "expo-auth-session": "~5.0.2",
    "expo-camera": "~13.4.4",
    "expo-constants": "~14.4.2",
    "expo-crypto": "~12.4.1",
    "expo-device": "~5.4.0",
    "expo-font": "~11.4.0",
